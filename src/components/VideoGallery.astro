---
import { getLatestVODs, getLatestClips, getTwitchUserId } from '../lib/twitch.js';

const userId = await getTwitchUserId('roisthecat');
const vods = await getLatestVODs(userId, 6);
const clips = await getLatestClips(userId, 6);
---

<section id="directos" class="py-24 px-6 bg-cream">

  <!-- Cabecera -->
  <div class="max-w-6xl mx-auto mb-12 text-center">
    <p class="text-pink-400 font-display font-bold text-sm tracking-[0.3em] uppercase mb-2">✦ mis directos ✦</p>
    <h2 class="font-display font-black text-5xl text-deep mb-4">Últimos streams</h2>
    <p class="text-muted font-body text-lg">Revive los mejores momentos de Twitch 🎮</p>
  </div>

  <!-- Stream en directo -->
  <div class="max-w-6xl mx-auto mb-16">
    <div class="flex items-center gap-3 mb-6">
      <span class="w-3 h-3 rounded-full bg-red-500 animate-pulse inline-block"></span>
      <h3 class="font-display font-bold text-xl text-deep">En directo ahora</h3>
    </div>
    <div class="rounded-3xl overflow-hidden shadow-xl border-2 border-pink-200 aspect-video">
      <iframe
        src="https://player.twitch.tv/?channel=roisthecat&parent=localhost"
        allowfullscreen
        class="w-full h-full"
      ></iframe>
    </div>
  </div>

  <!-- Tabs -->
  <div class="max-w-6xl mx-auto">

    <!-- Tab buttons -->
    <div class="flex gap-2 mb-8 bg-white border border-pink-200 rounded-full p-1.5 w-fit mx-auto shadow-sm">
      <button
        id="tab-vods"
        onclick="switchTab('vods')"
        class="tab-btn active-tab font-display font-bold text-sm px-6 py-2.5 rounded-full transition-all duration-300"
      >
        🎮 VODs recientes
      </button>
      <button
        id="tab-clips"
        onclick="switchTab('clips')"
        class="tab-btn font-display font-bold text-sm px-6 py-2.5 rounded-full transition-all duration-300"
      >
        ✂️ Clips destacados
      </button>
    </div>

    <!-- VODs panel -->
    <div id="panel-vods" class="tab-panel">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {vods.map((vod) => (
          <div class="rounded-2xl overflow-hidden shadow-md border border-pink-100 bg-white hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
            <div class="aspect-video">
              <iframe
                src={`https://player.twitch.tv/?video=${vod.id}&parent=localhost`}
                allowfullscreen
                class="w-full h-full"
              ></iframe>
            </div>
            <div class="px-4 py-3">
              <p class="font-display font-bold text-deep text-sm truncate">{vod.title}</p>
              <p class="font-body text-muted text-xs mt-1">{new Date(vod.created_at).toLocaleDateString('es-ES')}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Clips panel -->
    <div id="panel-clips" class="tab-panel hidden">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {clips.map((clip) => (
          <div class="rounded-2xl overflow-hidden shadow-md border border-pink-100 bg-white hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
            <div class="aspect-video">
              <iframe
                src={`https://clips.twitch.tv/embed?clip=${clip.id}&parent=localhost`}
                allowfullscreen
                class="w-full h-full"
              ></iframe>
            </div>
            <div class="px-4 py-3">
              <p class="font-display font-bold text-deep text-sm truncate">{clip.title}</p>
              <p class="font-body text-muted text-xs mt-1">{new Date(clip.created_at).toLocaleDateString('es-ES')}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

  </div>

</section>

<style>
  .tab-btn {
    color: rgba(30, 10, 60, 0.5);
  }

  .active-tab {
    background-color: #a855f7;
    color: white;
    box-shadow: 0 4px 12px rgba(168, 85, 247, 0.3);
  }
</style>

<script>
  function switchTab(tab: string) {
    const panels = document.querySelectorAll('.tab-panel');
    const buttons = document.querySelectorAll('.tab-btn');

    panels.forEach(p => p.classList.add('hidden'));
    buttons.forEach(b => b.classList.remove('active-tab'));

    document.getElementById(`panel-${tab}`)?.classList.remove('hidden');
    document.getElementById(`tab-${tab}`)?.classList.add('active-tab');
  }

  (window as any).switchTab = switchTab;
</script>