---
---

<section class="relative min-h-screen flex flex-col items-center justify-between overflow-hidden bg-cream px-6 py-24">

  <!-- Fondo con burbujas decorativas -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-10 left-10 w-64 h-64 rounded-full bg-blush opacity-40 blur-3xl"></div>
    <div class="absolute bottom-20 right-10 w-80 h-80 rounded-full bg-lavender opacity-40 blur-3xl"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-96 rounded-full bg-pink-100 opacity-30 blur-3xl"></div>
  </div>

  <!-- Ticker marquee superior -->
  <div class="absolute top-0 left-0 w-full bg-pink-400 py-2 overflow-hidden">
    <div class="flex whitespace-nowrap animate-marquee gap-8">
      {Array(12).fill(null).map(() => (
        <span class="text-white font-display font-bold text-sm tracking-widest uppercase">
          ✦ roisthecat &nbsp; 🎮 gaming &nbsp; 🌸 kpop &nbsp; 🎌 anime &nbsp; 🎬 kdrama &nbsp;
        </span>
      ))}
    </div>
  </div>

  <!-- Contenido principal -->
  <div class="relative z-10 flex flex-col items-center text-center gap-6 my-auto">

    <!-- Avatar decorativo -->
    <div class="relative animate-float">
      <div class="w-40 h-40 rounded-full overflow-hidden shadow-2xl border-4 border-white">
        <img src="/images/profile.png" alt="roisthecat" class="w-full h-full object-cover" />
      </div>
      <!-- Badges flotantes -->
      <span class="absolute -top-2 -right-2 bg-white rounded-full px-2 py-1 text-lg shadow-md border border-pink-100">🎮</span>
      <span class="absolute -bottom-2 -left-2 bg-white rounded-full px-2 py-1 text-lg shadow-md border border-pink-100">🌸</span>
    </div>

    <!-- Nombre -->
    <div class="opacity-0 animate-fade-up" style="animation-delay: 0.1s; animation-fill-mode: forwards;">
      <p class="text-pink-400 font-display font-bold text-sm tracking-[0.3em] uppercase mb-1">✦ streamer & gamer ✦</p>
      <h1 class="font-display font-black text-6xl md:text-8xl text-deep leading-none">
        rois<span class="text-pink-400">the</span>cat
      </h1>
    </div>

    <!-- Descripción -->
    <div class="opacity-0 animate-fade-up" style="animation-delay: 0.25s; animation-fill-mode: forwards;">
      <p class="text-deep/60 font-body text-lg md:text-xl max-w-md leading-relaxed">
        Videojuegos, anime, kdramas y mucho kpop.<br/>
        <span class="text-pink-400 font-semibold">Bienvenida/o a mi mundo 🎀</span>
      </p>
    </div>

    <!-- Tags de intereses -->
    <div class="opacity-0 animate-fade-up flex flex-wrap justify-center gap-2 max-w-sm" style="animation-delay: 0.4s; animation-fill-mode: forwards;">
      {['🎮 Gaming', '🎌 Anime', '🎬 Kdrama', '🎵 Kpop', '🐱 Cat lover'].map(tag => (
        <span class="bg-white border border-pink-200 text-deep/70 font-body text-sm px-4 py-1.5 rounded-full shadow-sm hover:bg-pink-50 hover:border-pink-300 transition-colors cursor-default">
          {tag}
        </span>
      ))}
    </div>

    <!-- CTA -->
    <div class="opacity-0 animate-fade-up flex gap-4" style="animation-delay: 0.55s; animation-fill-mode: forwards;">
  
        <a href="https://www.twitch.tv/roisthecat"
            target="_blank"
            rel="noopener noreferrer"
            class="bg-pink-400 hover:bg-pink-500 text-white font-display font-bold text-base px-10 py-4 rounded-full shadow-lg transition-all duration-300 hover:-translate-y-0.5 text-center"
            >
            Ver en Twitch 💜
        </a>

        <a href="#directos"
            class="bg-white hover:bg-pink-50 text-deep font-display font-bold text-base px-10 py-4 rounded-full border-2 border-pink-200 shadow-sm transition-all duration-300 hover:-translate-y-0.5 text-center"
            >
            Mis directos 🎥
        </a>
    </div>

  </div>

  <!-- Flecha scroll -->
    <a href="#directos" class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-float opacity-50 hover:opacity-100 transition-opacity cursor-pointer">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#ff5fa3" stroke-width="2">
            <path d="M12 5v14M5 12l7 7 7-7"/>
        </svg>
    </a>

</section>